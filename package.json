{
  "name": "smoke",
  "version": "0.1.0",
  "description": "Smoke — spatial terminal canvas",
  "main": "./out/main/index.js",
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild": "node scripts/patch-node-pty-spectre.js && electron-rebuild -f -w node-pty",
    "postinstall": "electron-vite build && node scripts/patch-node-pty-spectre.js && electron-rebuild",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:all": "npm run build && electron-builder --mac --win",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:headed": "npm run build && HEADED=1 npx playwright test",
    "test:e2e:only": "npx playwright test",
    "create-plugin": "node scripts/create-plugin.js",
    "bench": "vitest bench",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@replit/codemirror-lang-csharp": "^6.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "electron-store": "^10.0.0",
    "marked": "^17.0.4",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.0.2",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.smoke.app",
    "productName": "Smoke",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterSign": "scripts/notarize.js"
  },
  "overrides": {
    "electron": {
      "@electron/get": "^3.1.0",
      "extract-zip": {
        "yauzl": "^3.2.1"
      }
    },
    "@electron/asar": "^4.1.0",
    "global-agent": "^4.1.3",
    "cacache": {
      "glob": "^13.0.6"
    },
    "temp": {
      "rimraf": "^6.1.3"
    }
  }
}
